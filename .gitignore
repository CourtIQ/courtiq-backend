# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
vendor/

# Go workspace file
go.work

# IDE-specific files
.idea/
.vscode/
*.swp
*.swo

# OS-specific files
.DS_Store
Thumbs.db

# Environment variables
.env
deploy/.env.populated

# Compiled Object files, Static and Dynamic libs (Shared Objects)
*.o
*.a

# Log files
*.log

# Temporary files
*.tmp

# Docker volumes
data/
.docker/

# Build output
/build/
/dist/

# Node.js dependencies
/node_modules/

# Keep populate-env.sh in version control, but ignore start-dev.sh if it's not needed
# deploy/populate-env.sh
deploy/start-dev.sh

# Ignore any local override files
docker-compose.override.yml

# Ignore generated API documentation
/docs/api/

# Ignore any local backup files
*.bak

# Ignore any local database files
*.db